			"--allow-scripts yes",
			"",
			"# Connect Warehouse Transactions table",
			"dotnet new pp-app-code-data `",
			"--output \"src/Warehouse.CodeApp\" `",
			"--ModelSolutionPath \"../Solutions.DataModel\" `",
			"--EntityLogicalName \"${${publisherPrefix}}_warehousetransaction\" `",
			"--allow-scripts yes",
			"",
		],
		"description": "Snippet for adding Dataverse table datasources via dotnet templates"
	},
	"Create a Dataverse solution project for a database schema": {
		"scope": "powershell",
		"prefix": "CFK09-create-solution-codeapp",
		"body": [
			"#",
			"# ╔══════════════════════════════════════════════════════════════════════════════════════╗",
			"# ║                CFK09: Create a Dataverse solution project for a Code App             ║",
			"# ╚══════════════════════════════════════════════════════════════════════════════════════╝",
			"#",
			"# Creates a Dataverse solution project that packages the Code App for deployment.",
			"# Uses the pp-solution dotnet template to scaffold the solution structure.",
			"#",
			"# After creation, wires up project references:",
			"#   1. Adds Warehouse.CodeApp.csproj as a reference to the solution project",
			"#   2. Adds the solution project as a reference to Packages.Main (Package Deployer)",
			"#",
			"# This ensures the Code App is included in the Dataverse solution during build",
			"# and deployed automatically via the Package Deployer pipeline.",
			"#",
			"# ────────────────────────────────────────────────────────────────────────────────────────",
			"#                                        Commands",
			"# ────────────────────────────────────────────────────────────────────────────────────────",
			"# Step 1: Create a solution project for the Code App using the installed template.",
			"dotnet new pp-solution `",
			"--output \"src\\\\${2:Solutions.CodeApp}\" `",
			"--PublisherName \"${3:UDPP}\" `",
			"--PublisherPrefix \"${4:udpp}\" `",
			"--allow-scripts yes",
			"",
			"# Step 2: Add the solution project to the Package Deployer project as a .NET ProjectReference item.",
			"cd src/Solutions.CodeApp",
			"dotnet add \"./Solutions.CodeApp.csproj\" reference \"../Warehouse.CodeApp/Warehouse.CodeApp.csproj\"",
			"cd ../..",
			"",
			"# Step 2: Add the solution project to the Package Deployer project as a .NET ProjectReference item.",
			"cd src/Packages.Main",
			"dotnet add \"./Packages.Main.csproj\" reference \"../${2:Solutions.CodeApp}/${2:Solutions.CodeApp}.csproj\"",
			"cd ../..",
			"",
			"# Step 3: build solution",
			"cd src/Solutions.CodeApp",
			"dotnet publish -c Release ",
			"cd ../..",
		],
		"description": "Create a Dataverse solution project for a Code App and wire it to Package Deployer"
	}
}